{
	"name": "@gooonzick/wizard-vue",
	"version": "1.3.0",
	"description": "Vue 3 integration for Wizard framework",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "vite build",
		"typecheck": "tsc --build --verbose",
		"test": "vitest --run",
		"test:watch": "vitest --watch",
		"lint": "biome check .",
		"lint:fix": "biome check . --write"
	},
	"peerDependencies": {
		"vue": "^3.5.27"
	},
	"dependencies": {
		"@gooonzick/wizard-core": "workspace:*",
		"@gooonzick/wizard-state": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/node": "^24.10.9",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.2",
		"@vue/test-utils": "^2.4.6",
		"happy-dom": "^20.0.11",
		"typescript": "^6.0.2",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.2",
		"vue": "^3.5.27"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gooonzick/wizard",
		"directory": "packages/vue"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"wizard",
		"vue",
		"composable",
		"form",
		"multi-step"
	]
}
