{
	"name": "@gooonzick/wizard-core",
	"version": "1.4.0",
	"description": "Core package for WizardForm framework",
	"type": "module",
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./plugins": {
			"types": "./dist/plugins/index.d.ts",
			"import": "./dist/plugins.js"
		}
	},
	"scripts": {
		"build": "vite build",
		"typecheck": "tsc --build --verbose",
		"test": "vitest --run",
		"test:watch": "vitest --watch",
		"lint": "biome check .",
		"lint:fix": "biome check . --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@vitest/coverage-v8": "^4.1.2",
		"typescript": "^6.0.2",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.1.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gooonzick/wizard",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public"
	}
}
